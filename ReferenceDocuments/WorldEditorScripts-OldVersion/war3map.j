function Trig_Up_Fortress_Actions takes nothing returns nothing
 DisableTrigger(gg_trg_Market_1)
set udg_TempPoint[1]=GetUnitLoc(GetDyingUnit())
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=24
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
 CreateNUnitsAtLoc(1,'u000',udg_Player_Up2,udg_TempPoint[1],bj_UNIT_FACING)
 UnitAddAbilityBJ('A051',GetLastCreatedUnit())
 IssuePointOrderLocBJ(GetLastCreatedUnit(),"shockwave",PolarProjectionBJ(udg_TempPoint[1],100.00,(75.00+(I2R(GetForLoopIndexA())*15.00))))
 UnitApplyTimedLifeBJ(5.00,'BTLF',GetLastCreatedUnit())
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
 QuestMessageBJ(GetPlayersAll(),bj_QUESTMESSAGE_FAILED,((udg_Player_Colors[1]+(GetPlayerName(GetOwningPlayer(GetDyingUnit()))+""))+" has  his Fortress!"))
 TriggerSleepAction(1.00)
set udg_TempGroup[13]=GetUnitsInRectMatching(gg_rct_AreaUp,Condition(function Trig_Up_Fortress_Func006002002))
 ForGroupBJ(udg_TempGroup[13],function Trig_Up_Fortress_Func007002)
 DestroyGroup(udg_TempGroup[13])
 RemoveLocation(udg_TempPoint[1])
