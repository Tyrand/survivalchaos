 CreateTextTagLocBJ(("+"+I2S(udg_Passive_Gold[9])),udg_TempPoint[12],0,10,100.00,100.00,0.00,0)
 SetTextTagVelocityBJ(GetLastCreatedTextTag(),40.00,90)
 SetTextTagPermanentBJ(GetLastCreatedTextTag(),false)
 SetTextTagLifespanBJ(GetLastCreatedTextTag(),7.00)
 SetTextTagFadepointBJ(GetLastCreatedTextTag(),4.00)
else
