function Trig_SpUpL_Actions takes nothing returns nothing
 StartTimerBJ(udg_SpTimerUpL,false,udg_SpRateUpL)
set udg_SpwPoint[1]=GetRectCenter(gg_rct_SpUpL)
if(Trig_SpUpL_Func003C())then
 CreateNUnitsAtLoc(udg_Number_Tech[1],udg_Tech_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
else
 DoNothing()
endif
 CreateNUnitsAtLoc(udg_Number_Melee[1],udg_Melee_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
 CreateNUnitsAtLoc(udg_Number_Ranged[1],udg_Range_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
 CreateNUnitsAtLoc(udg_Number_Mage[1],udg_Mage_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
if(Trig_SpUpL_Func008C())then
 CreateNUnitsAtLoc(udg_Number_Mounted[1],udg_Mounted_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
else
 DoNothing()
endif
if(Trig_SpUpL_Func009C())then
 CreateNUnitsAtLoc(udg_Number_Air[1],udg_Air_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
else
 DoNothing()
endif
if(Trig_SpUpL_Func010C())then
if(Trig_SpUpL_Func010Func001C())then
if(Trig_SpUpL_Func010Func001Func002C())then
 CreateNUnitsAtLoc(udg_Number_Artillery[1],udg_Artillery_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
set udg_Artillery_Spawn[1]=2
else
set udg_Artillery_Spawn[1]=1
endif
else
 CreateNUnitsAtLoc(udg_Number_Artillery[1],udg_Artillery_Unit[1],udg_Player_Up2,udg_SpwPoint[1],225.00)
endif
else
 DoNothing()
endif
set udg_SpawnTimerNr[1]=R2I(udg_SpRateUpL)
 TriggerSleepAction(0.30)
set udg_TempGroup[1]=GetUnitsInRectOfPlayer(gg_rct_SpUpL,udg_Player_Up2)
 ForGroupBJ(udg_TempGroup[1],function Trig_SpUpL_Func014002)
 DestroyGroup(udg_TempGroup[1])
 RemoveLocation(udg_SpwPoint[1])
endfunction
