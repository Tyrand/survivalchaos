function Trig_Blood_Elf_Ulti_A_Actions takes nothing returns nothing
set udg_TempPointUlti[8]=GetUnitLoc(GetTriggerUnit())
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=12
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
 CreateNUnitsAtLoc(1,'u000',GetOwningPlayer(GetTriggerUnit()),udg_TempPointUlti[8],bj_UNIT_FACING)
 UnitAddAbilityBJ('A06P',GetLastCreatedUnit())
 IssuePointOrderLocBJ(GetLastCreatedUnit(),"shockwave",PolarProjectionBJ(udg_TempPointUlti[8],100.00,(60.00+(I2R(GetForLoopIndexA())*30.00))))
 UnitApplyTimedLifeBJ(5.00,'BTLF',GetLastCreatedUnit())
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
 TriggerSleepAction(0.50)
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=12
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
 CreateNUnitsAtLoc(1,'u000',GetOwningPlayer(GetTriggerUnit()),udg_TempPointUlti[8],bj_UNIT_FACING)
 UnitAddAbilityBJ('A06P',GetLastCreatedUnit())
 IssuePointOrderLocBJ(GetLastCreatedUnit(),"shockwave",PolarProjectionBJ(udg_TempPointUlti[8],100.00,(45.00+(I2R(GetForLoopIndexA())*30.00))))
 UnitApplyTimedLifeBJ(5.00,'BTLF',GetLastCreatedUnit())
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
 TriggerSleepAction(0.30)
 RemoveLocation(udg_TempPointUlti[8])
endfunction
