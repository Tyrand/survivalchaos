 AdjustPlayerStateBJ(150,udg_Player_Left1,PLAYER_STATE_RESOURCE_GOLD)
set udg_TempPoint[54]=GetUnitLoc(GetTriggerUnit())
 CreateTextTagLocBJ("+150",udg_TempPoint[54],0,10,100.00,100.00,0.00,0)
 SetTextTagVelocityBJ(GetLastCreatedTextTag(),40.00,90)
 SetTextTagPermanentBJ(GetLastCreatedTextTag(),false)
 SetTextTagLifespanBJ(GetLastCreatedTextTag(),7.00)
 SetTextTagFadepointBJ(GetLastCreatedTextTag(),4.00)
 RemoveLocation(udg_TempPoint[54])
set udg_Item_Count[4]=0
else
 DisplayTimedTextToForce(GetPlayersAllies(GetOwningPlayer(GetTriggerUnit())),10.00,"Hero has no items!")
endif
else
 DoNothing()
endif
endif
endif
endif
 TriggerSleepAction(0.30)
 EnableTrigger(GetTriggeringTrigger())
endfunction
