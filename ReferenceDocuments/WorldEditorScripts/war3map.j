set Q70I=Q70I+1
exitwhen Q70I>bj_MAX_ITEM_LEVEL
endloop
if(Q81I==0)then
set Q8OI=null
return
endif
 Q78I(Q8OI,Q8II)
set Q8OI=null
endfunction
