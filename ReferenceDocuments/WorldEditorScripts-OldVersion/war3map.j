function Trig_HeroUpBuyA_Conditions takes nothing returns boolean
if(not(GetUnitTypeId(GetSoldUnit())==udg_Hero_Unit_A[1]))then
return false
endif
if(not(GetOwningPlayer(GetSellingUnit())==udg_Player_Up1))then
return false
endif
return true
endfunction
function Trig_HeroUpBuyA_Actions takes nothing returns nothing
 SetPlayerTechMaxAllowedSwap(udg_Hero_Unit_A[1],1,udg_Player_Up1)
endfunction
function InitTrig_HeroUpBuyA takes nothing returns nothing
set gg_trg_HeroUpBuyA=CreateTrigger()
 TriggerRegisterAnyUnitEventBJ(gg_trg_HeroUpBuyA,EVENT_PLAYER_UNIT_SELL)
 TriggerAddCondition(gg_trg_HeroUpBuyA,Condition(function Trig_HeroUpBuyA_Conditions))
 TriggerAddAction(gg_trg_HeroUpBuyA,function Trig_HeroUpBuyA_Actions)
endfunction
function Trig_HeroUpBuyAA_Conditions takes nothing returns boolean
if(not(GetUnitTypeId(GetEnteringUnit())==udg_Hero_Unit_A[1]))then
return false
endif
return true
endfunction
function Trig_HeroUpBuyAA_Func002Func001C takes nothing returns boolean
if(not(GetRandomInt(1,3)<=2))then
return false
endif
return true
endfunction
function Trig_HeroUpBuyAA_Func002C takes nothing returns boolean
if(not(udg_Items_Alowed[1]==true))then
return false
endif
return true
endfunction
function Trig_HeroUpBuyAA_Actions takes nothing returns nothing
 DisableTrigger(GetTriggeringTrigger())
if(Trig_HeroUpBuyAA_Func002C())then
if(Trig_HeroUpBuyAA_Func002Func001C())then
