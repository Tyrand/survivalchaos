function Trig_Blood_Elf_Whirlwind_Actions takes nothing returns nothing
if(Trig_Blood_Elf_Whirlwind_Func001C())then
 DisableTrigger(GetTriggeringTrigger())
set udg_TempPoint[34]=GetUnitLoc(GetAttackedUnitBJ())
set udg_TempGroup[34]=GetUnitsInRangeOfLocMatching(350.00,udg_TempPoint[34],Condition(function Trig_Blood_Elf_Whirlwind_Func001Func004002003))
 SetUnitAnimation(GetAttackedUnitBJ(),"slam")
 AddSpecialEffectLocBJ(udg_TempPoint[34],"Abilities\\Spells\\NightElf\\FanOfKnives\\FanOfKnivesCaster.mdl")
set udg_TempEffect[1]=GetLastCreatedEffectBJ()
 ForGroupBJ(udg_TempGroup[34],function Trig_Blood_Elf_Whirlwind_Func001Func008A)
 RemoveLocation(udg_TempPoint[34])
 DestroyGroup(udg_TempGroup[34])
 TriggerSleepAction(1.00)
 DestroyEffectBJ(udg_TempEffect[1])
 TriggerSleepAction(2.00)
 EnableTrigger(GetTriggeringTrigger())
else
 DoNothing()
endif
endfunction
