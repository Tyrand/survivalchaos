function Trig_Race_Autopick_A_Actions takes nothing returns nothing
set udg_Random_Pick[1]=GetRandomInt(1,12)
set udg_Random_Pick[2]=GetRandomInt(1,12)
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=100
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
if(Trig_Race_Autopick_A_Func003Func001C())then
set udg_Random_Pick[2]=GetRandomInt(1,12)
else
 DoNothing()
endif
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
set udg_Random_Pick[3]=GetRandomInt(1,12)
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=200
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
if(Trig_Race_Autopick_A_Func005Func001C())then
set udg_Random_Pick[3]=GetRandomInt(1,12)
else
 DoNothing()
endif
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
set udg_Random_Pick[4]=GetRandomInt(1,12)
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=300
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
if(Trig_Race_Autopick_A_Func007Func001C())then
set udg_Random_Pick[4]=GetRandomInt(1,12)
else
 DoNothing()
endif
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
 IssueTrainOrderByIdBJ(udg_Fortress_Up,udg_Races[udg_Random_Pick[1]])
 TriggerSleepAction(0.10)
 IssueTrainOrderByIdBJ(udg_Fortress_Right,udg_Races[udg_Random_Pick[2]])
 TriggerSleepAction(0.10)
 IssueTrainOrderByIdBJ(udg_Fortress_Down,udg_Races[udg_Random_Pick[3]])
 TriggerSleepAction(0.10)
 IssueTrainOrderByIdBJ(udg_Fortress_Left,udg_Races[udg_Random_Pick[4]])
 DisableTrigger(gg_trg_Deselect)
 SelectUnitForPlayerSingle(udg_Fortress_Down,udg_Player_Down1)
 SelectUnitForPlayerSingle(udg_Fortress_Left,udg_Player_Left1)
 SelectUnitForPlayerSingle(udg_Fortress_Right,udg_Player_Right1)
 SelectUnitForPlayerSingle(udg_Fortress_Up,udg_Player_Up1)
 TriggerSleepAction(2)
 TriggerExecute(gg_trg_Initialize_Timers)
endfunction
