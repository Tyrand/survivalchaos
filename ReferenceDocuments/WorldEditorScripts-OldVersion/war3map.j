function Trig_Magic_Mushroom_2_Conditions takes nothing returns boolean
if(not(GetUnitTypeId(GetAttacker())=='odoc'))then
return false
endif
if(not(IsUnitType(GetAttackedUnitBJ(),UNIT_TYPE_STRUCTURE)==false))then
return false
endif
if(not(IsUnitType(GetAttackedUnitBJ(),UNIT_TYPE_HERO)==false))then
return false
endif
if(not(IsUnitType(GetAttackedUnitBJ(),UNIT_TYPE_MECHANICAL)==false))then
return false
endif
if(not(GetUnitLifePercent(GetAttackedUnitBJ())>=40.00))then
return false
endif
return true
endfunction
