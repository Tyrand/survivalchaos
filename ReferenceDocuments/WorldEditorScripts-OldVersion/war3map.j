function Trig_Set_Game_Level_Actions takes nothing returns nothing
 DisableTrigger(GetTriggeringTrigger())
 DisableTrigger(gg_trg_Sleepy_Ass)
 ClearTextMessagesBJ(GetPlayersAll())
 DialogDisplayBJ(false,udg_Game_Mode,Player(5))
 DialogDisplayBJ(false,udg_Game_Mode,Player(7))
 DialogDisplayBJ(false,udg_Game_Mode,Player(9))
 DialogDisplayBJ(false,udg_Game_Mode,Player(10))
if(Trig_Set_Game_Level_Func009C())then
set udg_Apem=false
set udg_Mode_Type="Standard Random"
 EnableTrigger(gg_trg_Deselect)
 DisplayTimedTextToForce(GetPlayersAll(),10.00,"Mode: Random / Neutrals ON")
 StartTimerBJ(udg_StartCountdown,false,1.00)
 CreateTimerDialogBJ(udg_StartCountdown,"Game starts in")
set udg_CountdownWindow=GetLastCreatedTimerDialogBJ()
 PanCameraToTimedLocForPlayer(udg_Player_Down1,GetUnitLoc(udg_Fortress_Down),0)
 SetCameraFieldForPlayer(udg_Player_Down1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
 PanCameraToTimedLocForPlayer(udg_Player_Left1,GetUnitLoc(udg_Fortress_Left),0)
 SetCameraFieldForPlayer(udg_Player_Left1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
 PanCameraToTimedLocForPlayer(udg_Player_Right1,GetUnitLoc(udg_Fortress_Right),0)
 SetCameraFieldForPlayer(udg_Player_Right1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
 PanCameraToTimedLocForPlayer(udg_Player_Up1,GetUnitLoc(udg_Fortress_Up),0)
 SetCameraFieldForPlayer(udg_Player_Up1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
else
if(Trig_Set_Game_Level_Func009Func016C())then
set udg_Apem=true
set udg_Mode_Type="Standard All Pick"
 DisableTrigger(gg_trg_Deselect)
 DisplayTimedTextToForce(GetPlayersAll(),10.00,"Mode: All Pick / Neutrals ON")
 StartTimerBJ(udg_StartCountdown,false,30.00)
 CreateTimerDialogBJ(udg_StartCountdown,"Game starts in")
set udg_CountdownWindow=GetLastCreatedTimerDialogBJ()
 PanCameraToTimedLocForPlayer(udg_Player_Down1,GetUnitLoc(udg_Fortress_Down),0)
 SelectUnitForPlayerSingle(udg_Fortress_Down,udg_Player_Down1)
 SetCameraFieldForPlayer(udg_Player_Down1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
 PanCameraToTimedLocForPlayer(udg_Player_Left1,GetUnitLoc(udg_Fortress_Left),0)
 SelectUnitForPlayerSingle(udg_Fortress_Left,udg_Player_Left1)
 SetCameraFieldForPlayer(udg_Player_Left1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
 PanCameraToTimedLocForPlayer(udg_Player_Right1,GetUnitLoc(udg_Fortress_Right),0)
 SelectUnitForPlayerSingle(udg_Fortress_Right,udg_Player_Right1)
 SetCameraFieldForPlayer(udg_Player_Right1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
 PanCameraToTimedLocForPlayer(udg_Player_Up1,GetUnitLoc(udg_Fortress_Up),0)
 SelectUnitForPlayerSingle(udg_Fortress_Up,udg_Player_Up1)
 SetCameraFieldForPlayer(udg_Player_Up1,CAMERA_FIELD_TARGET_DISTANCE,2300.00,1.00)
else
if(Trig_Set_Game_Level_Func009Func016Func003C())then
set udg_Apem=false
