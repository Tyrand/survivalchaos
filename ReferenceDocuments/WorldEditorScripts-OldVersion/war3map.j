function Trig_Left_Fortress_Actions takes nothing returns nothing
 DisableTrigger(gg_trg_Market_4)
set udg_TempPoint[4]=GetUnitLoc(GetDyingUnit())
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=24
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
 CreateNUnitsAtLoc(1,'u000',udg_Player_Left2,udg_TempPoint[4],bj_UNIT_FACING)
 UnitAddAbilityBJ('A051',GetLastCreatedUnit())
 IssuePointOrderLocBJ(GetLastCreatedUnit(),"shockwave",PolarProjectionBJ(udg_TempPoint[4],100.00,(75.00+(I2R(GetForLoopIndexA())*15.00))))
 UnitApplyTimedLifeBJ(5.00,'BTLF',GetLastCreatedUnit())
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
 QuestMessageBJ(GetPlayersAll(),bj_QUESTMESSAGE_FAILED,((udg_Player_Colors[4]+(GetPlayerName(GetOwningPlayer(GetDyingUnit()))+""))+" has  his Fortress!"))
 TriggerSleepAction(1.00)
set udg_TempGroup[16]=GetUnitsInRectMatching(gg_rct_AreaLeft,Condition(function Trig_Left_Fortress_Func006002002))
 ForGroupBJ(udg_TempGroup[16],function Trig_Left_Fortress_Func007002)
 DestroyGroup(udg_TempGroup[16])
 RemoveLocation(udg_TempPoint[4])
if(Trig_Left_Fortress_Func010C())then
 ShowTextTagForceBJ(false,udg_SpawnTimer[10],GetPlayersAll())
else
 DoNothing()
endif
if(Trig_Left_Fortress_Func011C())then
 ShowTextTagForceBJ(false,udg_SpawnTimer[11],GetPlayersAll())
else
 DoNothing()
endif
if(Trig_Left_Fortress_Func012C())then
 ShowTextTagForceBJ(false,udg_SpawnTimer[12],GetPlayersAll())
else
 DoNothing()
endif
endfunction
