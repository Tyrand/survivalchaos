function Trig_Templar_Gear_1_Actions takes nothing returns nothing
 SetUnitScalePercent(GetTriggerUnit(),90.00,90.00,90.00)
 SetPlayerTechResearchedSwap('R02E',1,GetOwningPlayer(GetTriggerUnit()))
if(Trig_Templar_Gear_1_Func003C())then
 SetPlayerTechResearchedSwap('R02E',1,udg_Player_Up2)
else
if(Trig_Templar_Gear_1_Func003Func001C())then
 SetPlayerTechResearchedSwap('R02E',1,udg_Player_Right2)
else
if(Trig_Templar_Gear_1_Func003Func001Func001C())then
 SetPlayerTechResearchedSwap('R02E',1,udg_Player_Down2)
else
if(Trig_Templar_Gear_1_Func003Func001Func001Func001C())then
 SetPlayerTechResearchedSwap('R02E',1,udg_Player_Left2)
else
endif
endif
endif
