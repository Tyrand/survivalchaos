function Trig_Undead_Nerub_Ulti_Actions takes nothing returns nothing
set udg_TempPoint[45]=GetUnitLoc(GetTriggerUnit())
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=16
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
 CreateNUnitsAtLoc(1,'u000',GetOwningPlayer(GetTriggerUnit()),udg_TempPoint[45],bj_UNIT_FACING)
 UnitAddAbilityBJ('A0DP',GetLastCreatedUnit())
 SetUnitAbilityLevelSwapped('A0DP',GetLastCreatedUnit(),GetUnitAbilityLevelSwapped('A0DO',GetTriggerUnit()))
 IssuePointOrderLocBJ(GetLastCreatedUnit(),"impale",PolarProjectionBJ(udg_TempPoint[45],100.00,(67.50+(I2R(GetForLoopIndexA())*22.50))))
 UnitApplyTimedLifeBJ(5.00,'BTLF',GetLastCreatedUnit())
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
 TriggerSleepAction(0.30)
 RemoveLocation(udg_TempPoint[45])
endfunction
