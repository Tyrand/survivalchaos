function Trig_Sell_Item_1_Actions takes nothing returns nothing
 DisableTrigger(GetTriggeringTrigger())
if(Trig_Sell_Item_1_Func002C())then
set udg_Item_Count[1]=UnitInventoryCount(udg_Hero_Unit_AA[1])
if(Trig_Sell_Item_1_Func002Func002C())then
 RemoveItem(UnitItemInSlotBJ(udg_Hero_Unit_AA[1],GetRandomInt(1,6)))
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=50
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
if(Trig_Sell_Item_1_Func002Func002Func003Func001C())then
 RemoveItem(UnitItemInSlotBJ(udg_Hero_Unit_AA[1],GetRandomInt(1,6)))
else
 DoNothing()
endif
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
 AdjustPlayerStateBJ(150,udg_Player_Up1,PLAYER_STATE_RESOURCE_GOLD)
set udg_TempPoint[51]=GetUnitLoc(GetTriggerUnit())
 CreateTextTagLocBJ("+150",udg_TempPoint[51],0,10,100.00,100.00,0.00,0)
 SetTextTagVelocityBJ(GetLastCreatedTextTag(),40.00,90)
 SetTextTagPermanentBJ(GetLastCreatedTextTag(),false)
 SetTextTagLifespanBJ(GetLastCreatedTextTag(),7.00)
 SetTextTagFadepointBJ(GetLastCreatedTextTag(),4.00)
 RemoveLocation(udg_TempPoint[51])
set udg_Item_Count[1]=0
else
 DisplayTimedTextToForce(GetPlayersAllies(GetOwningPlayer(GetTriggerUnit())),10.00,"Hero has no items!")
endif
else
if(Trig_Sell_Item_1_Func002Func003C())then
set udg_Item_Count[1]=UnitInventoryCount(udg_Hero_Unit_AA[2])
if(Trig_Sell_Item_1_Func002Func003Func002C())then
