set udg_TempPoint[47]=GetUnitLoc(GetAttackedUnitBJ())
 CreateNUnitsAtLoc(1,'u000',GetOwningPlayer(GetAttacker()),udg_TempPoint[47],bj_UNIT_FACING)
 UnitAddAbilityBJ('A0FC',GetLastCreatedUnit())
 IssueTargetOrderBJ(GetLastCreatedUnit(),"charm",GetAttackedUnitBJ())
 UnitApplyTimedLifeBJ(3.00,'BTLF',GetLastCreatedUnit())
 RemoveLocation(udg_TempPoint[47])
else
 DoNothing()
endif
 TriggerSleepAction(0.30)
 EnableTrigger(GetTriggeringTrigger())
endfunction
